<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent" android:background="@color/celesteBajo"
    android:layout_height="match_parent"
    tools:context=".MainJuego1">

    <ImageButton
        android:id="@+id/volver"
        android:contentDescription="Volver"
        android:src="@mipmap/retroceder_blanco_foreground"
        android:layout_width="50dp"
        android:background="#00000000" android:tooltipText="Volver" android:textDirection="locale"
        android:layout_height="50dp"  android:layout_margin="15dp"
        tools:ignore="MissingConstraints"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintLeft_toLeftOf="parent"/>

    <ImageButton
        android:id="@+id/learn"
        android:contentDescription="Volver"
        android:src="@mipmap/icono_learning"
        android:layout_width="50dp"
        android:background="#00000000" android:tooltipText="Aprender" android:textDirection="locale"
        android:layout_height="50dp"  android:layout_margin="15dp"
        tools:ignore="MissingConstraints" 
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintRight_toRightOf="parent"/>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/botones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:padding="15dp"
        >

        <!--Primera fila-->
        <ImageButton
            android:backgroundTint="@color/white"
            android:layout_width="150dp"
            android:contentDescription="Números"
            android:layout_height="150dp" android:id="@+id/numerosbtn"
            tools:ignore="MissingConstraints" />

        <ImageButton
            android:backgroundTint="@color/white"
            android:layout_width="150dp"
            android:contentDescription="Vocales"
            android:layout_height="150dp" android:id="@+id/vocalesbtn"
            app:layout_constraintLeft_toRightOf="@id/numerosbtn" android:layout_margin="10dp"
            tools:ignore="MissingConstraints" />

        <ImageButton
            android:backgroundTint="@color/white"
            android:layout_width="150dp"
            android:contentDescription="Letras" android:padding="0dp"
            android:layout_height="150dp" android:id="@+id/letrasbtn"
            app:layout_constraintLeft_toRightOf="@id/vocalesbtn" android:layout_margin="10dp"
            tools:ignore="MissingConstraints" />

        <ImageButton
            android:backgroundTint="@color/white"
            android:layout_width="150dp"
            android:contentDescription="Silabas" android:padding="0dp"
            android:layout_height="150dp" android:id="@+id/silabas"
            app:layout_constraintLeft_toRightOf="@id/letrasbtn" android:layout_margin="10dp"
            tools:ignore="MissingConstraints" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>