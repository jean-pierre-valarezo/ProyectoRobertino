<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    android:background="@color/celeste"
    tools:context=".MainActivity">


<!--    <com.airbnb.lottie.LottieAnimationView >-->

<!--    </com.airbnb.lottie.LottieAnimationView>-->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/titulo"
        android:layout_width="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/botones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_height="0dp" app:layout_constraintVertical_weight="1">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/animacion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_rawRes="@raw/menucara" />

       <LinearLayout
    android:id="@+id/tituloContenedor"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="-3dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:id="@+id/tituloParte1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ROBERTI"
        android:textSize="52sp"
        android:fontFamily="@font/mario"
        android:textColor="#FFFFFF"
        android:shadowColor="#000000"
        android:shadowRadius="6"
        android:shadowDx="0"
        android:shadowDy="0" />

    <TextView
    android:id="@+id/tituloEnie"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Ñ"
    android:textSize="58sp"
    android:textStyle="bold"
    android:fontFamily="@font/alpha_echo"
    android:textColor="#FFFFFF"
    android:shadowColor="#000000"
    android:shadowRadius="6"
    android:shadowDx="0"
    android:shadowDy="0"
    android:layout_marginTop="2dp"
    android:layout_marginStart="-2dp"
    android:layout_marginEnd="-4dp" />

    <TextView
        android:id="@+id/tituloParte2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="O"
        android:textSize="52sp"
        android:layout_marginTop="9dp"
        android:layout_marginStart="6dp"
        android:fontFamily="@font/mario"
        android:translationY="-9dp"
        android:textColor="#FFFFFF"
        android:shadowColor="#000000"
        android:shadowRadius="6"
        android:shadowDx="0"
        android:shadowDy="0" />
    </LinearLayout>

        <ImageButton
            android:id="@+id/config"
            android:contentDescription="Configurar"
            android:src="@mipmap/engranaje_foreground"
            android:layout_width="60dp"
            android:background="@drawable/rounded_button"
            app:layout_constraintTop_toTopOf="parent" android:tooltipText="Configurar" android:textDirection="locale"
            android:layout_height="60dp" app:layout_constraintRight_toRightOf="parent" android:layout_margin="15dp"
            tools:ignore="MissingConstraints" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/botones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titulo"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="0dp" android:padding="15dp"
        app:layout_constraintVertical_weight="1">


        <ImageButton
            android:backgroundTint="@color/celeste_pastel"
            android:text="BUSQUEDA"
            android:id="@+id/juego1"
            android:src="@mipmap/icon_search_foreground"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/juego2"
            tools:ignore="MissingConstraints"/>

        <ImageButton
            android:backgroundTint="@color/purpura_pastel"
            android:text="ADIVINANZAS"
            android:id="@+id/juego2"
            android:src="@mipmap/icon_riddle_foreground"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/juego1"
            app:layout_constraintEnd_toStartOf="@+id/juego3"
            tools:ignore="MissingConstraints"/>



        <ImageButton
            android:backgroundTint="@color/violeta_pastel"
            android:text="LECTURA"
            android:id="@+id/juego3"
            android:src="@mipmap/icon_read_foreground"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/juego2"
            app:layout_constraintEnd_toStartOf="@id/juego4"
            tools:ignore="MissingConstraints"/>


        <ImageButton
            android:id="@+id/juego4"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:backgroundTint="@color/rosado_pastel"
            android:src="@mipmap/icon_write_foreground"
            android:text="ESCRITURA"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/juego3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            tools:ignore="MissingConstraints"/>

        <!--        <Button-->
<!--            android:backgroundTint="@color/rojo_pastel"-->
<!--            android:text="CAZA"-->
<!--            android:id="@+id/juego5"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="0dp" -->
<!--            app:layout_constraintEnd_toEndOf="parent"-->
<!--            app:layout_constraintTop_toTopOf="parent"-->
<!--            app:layout_constraintBottom_toBottomOf="parent"-->
<!--            app:layout_constraintStart_toEndOf="@+id/juego4"-->

<!--            tools:ignore="MissingConstraints">-->

<!--        </Button>-->
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
