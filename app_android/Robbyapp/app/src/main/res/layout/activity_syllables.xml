<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ActivitySyllables">

    <ImageButton
        android:id="@+id/volver"
        android:contentDescription="Volver"
        android:src="@mipmap/retroceder_foreground"
        android:layout_width="50dp"
        android:background="#00000000"
        android:tooltipText="Volver"
        android:textDirection="locale"
        android:layout_height="50dp"
        android:layout_margin="15dp"
        app:layout_constraintLeft_toLeftOf="parent"
        tools:ignore="MissingConstraints"
        app:layout_constraintTop_toTopOf="parent"/>

    <com.airbnb.lottie.LottieAnimationView
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_height="match_parent"
        android:id="@+id/cara"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_rawRes="@raw/menucara"/>

    <TextView
        android:id="@+id/palabraTexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="__rro"
        android:textSize="32dp"
        android:textStyle="bold" android:textColor="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.234"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.877" />


    <!-- Botón 1: fila 1, columna 1 -->
    <Button
        android:id="@+id/opcion1"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:text="Opción 1"
        android:textSize="25dp"
        android:backgroundTint="@color/material_dynamic_tertiary70"
        android:textColor="@color/white"
        app:layout_constraintStart_toEndOf="@+id/cara"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/opcion2"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginRight="20dp"
        android:layout_marginTop="60dp"
        />

    <!-- Botón 2: fila 1, columna 2 -->
    <Button
        android:id="@+id/opcion2"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:text="Opción 2"
        android:textSize="25dp"
        android:textColor="@color/white"
        android:backgroundTint="@color/celeste"
        app:layout_constraintTop_toTopOf="@id/opcion1"
        app:layout_constraintStart_toEndOf="@id/opcion1"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <!-- Botón 3: fila 2, columna 1 -->
    <Button
        android:id="@+id/opcion3"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:text="Opción 3"
        android:textSize="25dp"
        android:backgroundTint="@color/rosado_pastel"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/opcion1"
        app:layout_constraintStart_toStartOf="@id/opcion1"
        />

    <!-- Botón 4: fila 2, columna 2 -->
    <Button
        android:id="@+id/opcion4"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:text="Opción 4"
        android:textSize="25dp"
        android:backgroundTint="@color/purple_500"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/opcion2"
        app:layout_constraintStart_toStartOf="@id/opcion2"
        />


    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/fireworks"
        android:layout_width="900dp"
        android:layout_height="900dp"
        android:visibility="gone"
        android:elevation="20dp"
        app:lottie_rawRes="@raw/fireworks"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
    android:id="@+id/repetirAudio"
    android:layout_width="50dp"
    android:layout_height="50dp"
    android:layout_margin="15dp"
    android:backgroundTint="#000000"
    android:tint="#FFFFFF"
    android:contentDescription="Repetir audio"
    android:src="@android:drawable/ic_lock_silent_mode_off"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
    android:id="@+id/mensajeResultado"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text=""
    android:textSize="30sp"
    android:textStyle="bold"
    android:textColor="#00C853"
    android:visibility="gone"
    android:elevation="40dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>
    

</androidx.constraintlayout.widget.ConstraintLayout>
