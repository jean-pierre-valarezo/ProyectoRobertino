<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
<!--    <style name="Theme.Robbyapp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">-->
    <style name="Theme.Robbyapp" parent="Theme.MaterialComponents.DayNight.NoActionBar">

    <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/celeste_pastel</item>

        <item name="android:windowBackground">@color/celeste_pastel</item>
        <item name="android:icon">@color/celeste_pastel</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="TopRoundedCardView" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Base.Theme.BottomNavigation" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/celeste_pastel</item>
        <item name="colorPrimaryVariant">@color/celeste_pastel</item>
        <item name="android:statusBarColor">@color/celeste_pastel</item>
    </style>

    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/celeste_pastel</item>
        <item name="android:paddingTop">30dp</item>
    </style>

    <style name="CustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">25sp</item> <!-- Aquí cambias el tamaño -->
        <item name="android:textColor">#000000</item> <!-- Opcional: color del texto -->
        <item name="android:textStyle">bold</item> <!-- Opcional: negrita -->
    </style>



</resources>